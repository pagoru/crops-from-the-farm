{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "es2022",
    "target": "es2022",
    "esModuleInterop": true,
    "sourceMap": false,
    "noUnusedLocals": true,
    "lib": ["es2023", "DOM"],
    "baseUrl": "./src",
    "rootDir": "./src",
    "jsx": "react",
    "paths": {
      "shared/*": ["shared/*"],
      "modules/*": ["modules/*"]
    },
    "allowImportingTsExtensions": true
  }
}
